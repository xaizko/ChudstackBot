{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"sourceMap": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "node_modules", "src/**/*.js", "src/**/*.js.map"]
}
